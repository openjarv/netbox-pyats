# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
build/
dist/
*.egg-info/
*.egg
pip-wheel-metadata/

# Virtual envs
.venv/
venv/
env/

# Test / coverage / cache
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp

# OS
.DS_Store

# Local NetBox dev state
dev/data/

# Graphify: commit the graph outputs, ignore cost + cache + internal state + backups
graphify-out/cost.json
graphify-out/cache/
graphify-out/.graphify_*
graphify-out/20*/

# Per-worktree dev environment (generated by scripts/dev-worktree.sh).
# Never commit these — they hold the per-worktree compose project name and
# claimed loopback port.
.env
.dev-port

# graphify-mcp HTTP api-key (ATW-42) — never commit.
dev/graphify-mcp/api-key
